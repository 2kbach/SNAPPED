{
  "manifest_version": 3,
  "name": "SNAPPED",
  "version": "0.1",
  "description": "Select UI elements and recreate them perfectly in Figma",
  "permissions": ["activeTab"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["shared/css-to-figma-mapper.js", "content/dom-extractor.js", "content/content.js"],
      "css": ["content/selector-overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/background.js"
  }
}
